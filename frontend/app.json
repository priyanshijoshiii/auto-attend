{
  "expo": {
    "name": "Auto-Attend",
    "slug": "auto-attend",
    "version": "1.0.0",
    "scheme": "auto-attend",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#F5F5F0"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.autoattend.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F5F5F0"
      },
      "package": "com.autoattend.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "FOREGROUND_SERVICE"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Auto-Attend needs your location to automatically mark attendance when you're in class.",
          "locationAlwaysPermission": "Auto-Attend needs background location access to mark attendance even when the app is closed.",
          "locationWhenInUsePermission": "Auto-Attend needs your location to detect when you're in class."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#5B8FD4"
        }
      ]
    ]
  }
}